# Last.fm
LASTFM_API_KEY=your_lastfm_api_key
LASTFM_API_SECRET=your_lastfm_api_secret
LASTFM_SESSION_KEY=your_lastfm_session_key
LASTFM_USERNAME=your_lastfm_username

# Discogs
DISCOGS_TOKEN=your_discogs_token
DISCOGS_USERNAME=your_discogs_username
DISCOGS_COLLECTION_FOLDER_ID=0

# Audio capture / recognition
AUDIO_INPUT_DEVICE=
AUDIO_SAMPLE_RATE=44100
AUDIO_CHANNELS=2
AUDIO_BLOCK_SECONDS=0.5
SHAZAM_CLIP_SECONDS=12
SILENCE_THRESHOLD=0.01
SILENCE_TOLERANCE_SECONDS=5
RECOGNITION_COOLDOWN_SECONDS=20
CLIP_STORAGE_DIRECTORY=runtime/clips
NOW_PLAYING_STATE_FILE=runtime/state/now_playing.json
LOG_LEVEL=INFO

# Matching
DISCOGS_MATCH_THRESHOLD=160
DISCOGS_CANDIDATE_LIMIT=8

# Lyrics display
LYRICS_HOST=0.0.0.0
LYRICS_PORT=8765
LYRICS_DIRECTORY=lyrics
LYRIC_TIMING_LEAD_SECONDS=0.35

# Oscilloscope smart plug
KASA_DEVICE_ALIAS=Oscilloscope
KASA_USERNAME=
KASA_PASSWORD=
OSCILLOSCOPE_IDLE_MINUTES=15
OSCILLOSCOPE_POLL_SECONDS=5
